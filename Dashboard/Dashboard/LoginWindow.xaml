<Window x:Class="Dashboard.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dashboard"
        mc:Ignorable="d"
        Title="Login" Height="350" Width="400">
    <Grid>
        <StackPanel Orientation="Vertical">
            <Label FontSize="50" FontWeight="DemiBold" HorizontalAlignment="Center" Margin="20">Login</Label>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Label FontSize="25" Margin="10">Username:</Label>
                <TextBox Height="35" Width="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Label FontSize="25" Margin="10">Password:</Label>
                <PasswordBox Height="35" Width="200"/>
            </StackPanel>
            <Button Height="35" Width="150" FontSize="20" FontWeight="DemiBold" Margin="20">Login</Button>
        </StackPanel>
    </Grid>
</Window>
